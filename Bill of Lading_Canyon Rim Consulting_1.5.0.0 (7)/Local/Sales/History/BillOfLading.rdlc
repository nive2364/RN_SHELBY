              <Textbox Name="Textbox23">
                <rd:DefaultName>Textbox23</rd:DefaultName>
                <CanGrow>true</CanGrow>
                <KeepTogether>true</KeepTogether>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>*If the shipment moves between two ports by a carrier by water, the law requires that the bill of lading state whether it is "carrier's or shippers's weight."</Value>
                        <Style>
                          <FontStyle>Normal</FontStyle>
                          <FontFamily>Times New Roman</FontFamily>
                          <FontSize>7pt</FontSize>
                          <FontWeight>Normal</FontWeight>
                          <TextDecoration>None</TextDecoration>
                          <Color>#000000</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <Style />
                  </Paragraph>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>NOTE - Where the rate is dependent on value shippers are required to state specifically in writing the agreed or declared value of the property.</Value>
                        <Style>
                          <FontStyle>Normal</FontStyle>
                          <FontFamily>Times New Roman</FontFamily>
                          <FontSize>7pt</FontSize>
                          <FontWeight>Normal</FontWeight>
                          <TextDecoration>None</TextDecoration>
                          <Color>#000000</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <LeftIndent>0.05208in</LeftIndent>
                    <RightIndent>0.33958in</RightIndent>
                    <Style>
                      <TextAlign>Left</TextAlign>
                      <LineHeight>11pt</LineHeight>
                    </Style>
                  </Paragraph>
                </Paragraphs>
                <Top>18.05543cm</Top>
                <Left>0.33964cm</Left>
                <Height>1.31438cm</Height>
                <Width>10.02067cm</Width>
                <ZIndex>57</ZIndex>
                <Style>
                  <Border>
                    <Style>None</Style>
                  </Border>
                  <PaddingLeft>2pt</PaddingLeft>
                  <PaddingRight>2pt</PaddingRight>
                  <PaddingTop>2pt</PaddingTop>
                  <PaddingBottom>2pt</PaddingBottom>
                </Style>
              </Textbox>
              <Textbox Name="Textbox24">
                <rd:DefaultName>Textbox24</rd:DefaultName>
                <CanGrow>true</CanGrow>
                <KeepTogether>true</KeepTogether>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>The agreed or declared value of the property is hereby specifically stated by the shipper to be not exceeding</Value>
                        <Style>
                          <FontStyle>Normal</FontStyle>
                          <FontFamily>Times New Roman</FontFamily>
                          <FontSize>7pt</FontSize>
                          <FontWeight>Bold</FontWeight>
                          <TextDecoration>None</TextDecoration>
                          <Color>#000000</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <Style />
                  </Paragraph>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>Liability Limitation for loss or damage on this shipment may be appicable. See 49 U.S.C. § 14706(c)(1)(A) and (B).</Value>
                        <Style>
                          <FontStyle>Normal</FontStyle>
                          <FontFamily>Times New Roman</FontFamily>
                          <FontSize>7pt</FontSize>
                          <FontWeight>Normal</FontWeight>
                          <TextDecoration>None</TextDecoration>
                          <Color>#000000</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <LeftIndent>0.05208in</LeftIndent>
                    <Style>
                      <TextAlign>Left</TextAlign>
                    </Style>
                  </Paragraph>
                </Paragraphs>
                <Top>19.29925cm</Top>
                <Left>0.31295cm</Left>
                <Height>1.24354cm</Height>
                <Width>9.93247cm</Width>
                <ZIndex>58</ZIndex>
                <Style>
                  <Border>
                    <Style>None</Style>
                  </Border>
                  <PaddingLeft>2pt</PaddingLeft>
                  <PaddingRight>2pt</PaddingRight>
                  <PaddingTop>2pt</PaddingTop>
                  <PaddingBottom>2pt</PaddingBottom>
                </Style>
              </Textbox>
              <Textbox Name="Textbox25">
                <rd:DefaultName>Textbox25</rd:DefaultName>
                <CanGrow>true</CanGrow>
                <KeepTogether>true</KeepTogether>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>† The fibre boxes used for this shipment conform to the specifications set forth in the box maker's certificate thereon,and all other requirements of Uniform Freight Classification."</Value>
                        <Style>
                          <FontStyle>Normal</FontStyle>
                          <FontFamily>Times New Roman</FontFamily>
