                                </LeftBorder>
                                <RightBorder>
                                  <Color>LightGrey</Color>
                                  <Style>Solid</Style>
                                  <Width>0.5pt</Width>
                                </RightBorder>
                                <BackgroundColor>=IIf(DateDiff("d", DateAdd("yyyy",-1,First(Fields!ExpirationDate.Value)), Today()) &gt;= 90, "Salmon",
    IIf(DateDiff("d", DateAdd("yyyy",-1,First(Fields!ExpirationDate.Value)), Today()) &gt;= 60, "Yellow", "Transparent"))</BackgroundColor>
                                <PaddingLeft>6pt</PaddingLeft>
                                <PaddingRight>2pt</PaddingRight>
                                <PaddingTop>2pt</PaddingTop>
                                <PaddingBottom>2pt</PaddingBottom>
                              </Style>
